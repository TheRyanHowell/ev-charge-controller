root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[Makefile]
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[ui/**/*.{ts,tsx,js,jsx,mjs,json}]
indent_style = space
indent_size = 2
