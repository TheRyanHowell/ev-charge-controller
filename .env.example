# Copy this file to .env and adjust values for your environment.
# This file is loaded automatically by `docker compose` via the Makefile.

# API server
PORT=8080
DB_PATH=/data/ev-charge.db
CORS_ORIGIN=http://localhost:3000

# UI server (server-side proxy to Go backend)
API_URL=http://api:8080

# Timezone - set to match your host so schedule activation aligns with your clock
TZ=Europe/London

# JWT auth - required, keep secret
# Generate with: openssl rand -hex 32
JWT_SECRET=

# MQTT broker (Mosquitto bundled with the app, using built-in dynamic security)
MQTT_PORT=1883

# MQTT credentials for the Go API backend.
# These are also used to bootstrap the Mosquitto dynsec admin account on first run.
# Set MQTT_BROKER_URL to enable the MQTT client; leave blank to disable MQTT.
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=api-backend
# Generate with: openssl rand -hex 32
MQTT_PASSWORD=

# LAN IP of the MQTT broker that Tasmota devices can reach (e.g., `192.168.0.10`)
# In production with macvlan this is the dedicated IP for the mosquitto container.
MQTT_IP=mosquitto
# MQTT port exposed on the LAN (default `1883`)
MQTT_EXTERNAL_PORT=1883

# Web Push (VAPID) - optional, only needed for push notifications
# Generate keys with: cd api && go run cmd/genkeys/main.go
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# HTTPS via Caddy reverse proxy - optional
# Set ENABLE_HTTPS to true, CADDY_DOMAIN to your domain,
# and CLOUDFLARE_API_KEY to your Cloudflare API token to enable HTTPS.
# Also update CORS_ORIGIN to https://<your-domain> when enabling HTTPS.
# Requires: DNS A record pointing CADDY_DOMAIN to your server's public IP.
# Cloudflare token needs DNS:Edit and Zone:Read permissions for the domain.
ENABLE_HTTPS=
CADDY_DOMAIN=
CLOUDFLARE_API_KEY=

# Mock Tasmota (dev mode only)
MOCK_TASMOTA_PORT=8081
MOCK_TASMOTA_POWER_WATTS=1510
MOCK_TASMOTA_VOLTAGE=230
MOCK_TASMOTA_FREQUENCY=50
MOCK_TASMOTA_2_POWER_WATTS=2200
MOCK_TASMOTA_3_POWER_WATTS=50

# Macvlan networking - required when ENABLE_HTTPS=true or when mosquitto needs a LAN IP
# First create the macvlan network (adjust parent/subnet/gateway for your setup):
#
#   docker network create -d macvlan \
#     --subnet=192.168.0.0/24 \
#     --gateway=192.168.0.1 \
#     -o parent=enp39s0 \
#     docker-macvlan
#
# Caddy: set CADDY_IP to an available IP in your subnet, CADDY_MAC to a unique MAC.
# Mosquitto (macvlan overlay): set MQTT_IP and MQTT_MAC similarly.
# Reserve these IPs for the MACs in your router DHCP.
CADDY_IP=
CADDY_MAC=
MQTT_MAC=
