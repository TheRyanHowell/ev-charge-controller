{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["public/sw.js", "src/test/mocks/**/*.ts"],
  "ignore": [".next/**"],
  "ignoreDependencies": [
    "typescript-eslint",
    "postcss",
    "eslint-plugin-testing-library",
    "tsx"
  ],
  "rules": {
    "files": "error",
    "exports": "error",
    "types": "error",
    "nsExports": "error",
    "nsTypes": "error",
    "duplicates": "error",
    "enumMembers": "error",
    "classMembers": "error",
    "dependencies": "off",
    "devDependencies": "off",
    "optionalPeerDependencies": "off",
    "unlisted": "off",
    "unresolved": "off",
    "binaries": "off"
  }
}
